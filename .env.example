# Local development (copy this to .env and update values)
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-to-a-long-random-string-in-production

# For local Docker MongoDB (default):
MONGODB_URI=mongodb://miniapty:miniapty@localhost:27017/miniapty?authSource=admin
# For MongoDB Atlas (replace with your actual URI, URL-encode special chars in password):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority&appName=YourApp

MONGODB_DB=miniapty
CORS_ORIGIN=*

# Extension build (set before pnpm build:extension)
VITE_API_BASE_URL=http://localhost:3001
