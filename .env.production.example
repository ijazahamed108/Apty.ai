# Production — backend (Vercel / Render / GitLab)
NODE_ENV=production
JWT_SECRET=generate-a-long-random-secret-min-32-chars

# MongoDB Atlas URI (replace with your actual credentials)
# IMPORTANT: URL-encode special characters in password (@→%40, #→%23, etc.)
MONGODB_URI=mongodb+srv://USERNAME:URL_ENCODED_PASSWORD@cluster.mongodb.net/DB_NAME?retryWrites=true&w=majority&appName=YourApp
MONGODB_DB=miniapty

# CORS origin (set to your frontend URL or * for development)
CORS_ORIGIN=https://your-extension-or-frontend-domain.com

# Production — extension build (bake into dist at build time)
VITE_API_BASE_URL=https://your-api.vercel.app
