{
  "name": "mini-apty",
  "version": "1.0.0",
  "private": true,
  "description": "Mini Apty — MERN stack Chrome extension + API (TypeScript strict)",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev:backend": "pnpm --filter @mini-apty/shared build && pnpm --filter backend dev",
    "dev:extension": "pnpm --filter @mini-apty/shared build && pnpm --filter extension dev",
    "dev:web": "pnpm --filter web dev",
    "build:backend": "pnpm --filter @mini-apty/shared build && pnpm --filter backend build",
    "build:web": "pnpm --filter web build",
    "build:vercel": "pnpm build:backend && pnpm build:web && node scripts/verify-vercel-output.mjs",
    "build:extension": "pnpm --filter @mini-apty/shared build && pnpm --filter extension build",
    "test:backend": "pnpm --filter backend test",
    "build": "pnpm build:backend && pnpm build:extension",
    "test": "pnpm test:backend",
    "start:backend": "node packages/backend/dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@vercel/node": "^5.1.14"
  }
}
