{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "mini-apty",
  "installCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile=false --prod=false",
  "buildCommand": "pnpm --filter @mini-apty/shared build && pnpm --filter backend build",
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/auth/(.*)", "destination": "/api" },
    { "source": "/walkthroughs/(.*)", "destination": "/api" },
    { "source": "/walkthroughs", "destination": "/api" }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  }
}
