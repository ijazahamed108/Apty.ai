{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "mini-apty",
  "framework": null,
  "installCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile=false --prod=false",
  "buildCommand": "pnpm --filter @mini-apty/shared build && pnpm --filter backend build",
  "outputDirectory": "public",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 30
      }
    }
  ],
  "routes": [
    {
      "src": "/health",
      "dest": "api/index.ts"
    },
    {
      "src": "/auth/(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/walkthroughs(.*)",
      "dest": "api/index.ts"
    },
    {
      "src": "/",
      "dest": "api/index.ts"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.ts"
    }
  ]
}
