{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "mini-apty",
  "installCommand": "npm install -g pnpm@9 && pnpm install --frozen-lockfile=false --prod=false",
  "buildCommand": "pnpm -w run build:vercel",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/health", "destination": "/api/health" },
    { "source": "/auth/(.*)", "destination": "/api/auth/$1" },
    { "source": "/walkthroughs/(.*)", "destination": "/api/walkthroughs/$1" },
    { "source": "/walkthroughs", "destination": "/api/walkthroughs" }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  }
}
